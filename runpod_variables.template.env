SAFETENSORS_API_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
SAFETENSORS_PANEL_USER=CHANGE_ME_PANEL_USER
SAFETENSORS_PANEL_PASSWORD=CHANGE_ME_STRONG_PANEL_PASSWORD
HF_TOKEN=
HF_HUB_ENABLE_HF_TRANSFER=1

SAFETENSORS_VOLUME_ROOT=/workspace
SAFETENSORS_MODELS_DIR=/workspace/models/safetensors
SAFETENSORS_STATE_DIR=/workspace/.state/safetensors-rig
SAFETENSORS_LOG_DIR=/workspace/logs/safetensors-rig
SAFETENSORS_STARTUP_LOG=/workspace/logs/safetensors-rig/startup.log
SAFETENSORS_API_HOST=0.0.0.0
SAFETENSORS_API_PORT=8000
SAFETENSORS_PANEL_HOST=0.0.0.0
SAFETENSORS_PANEL_PORT=7860
SAFETENSORS_HEALTH_TIMEOUT=600
SAFETENSORS_STOP_TIMEOUT=30
SAFETENSORS_SKIP_INSTALL=0
SAFETENSORS_ALLOW_INSECURE=0
SAFETENSORS_VENV_DIR=/workspace/.venvs/safetensors-rig
SAFETENSORS_VENV_SYSTEM_SITE_PACKAGES=1
SAFETENSORS_INSTALL_VLLM=auto
SAFETENSORS_EXPECTED_VLLM_VERSION=0.11.0
SAFETENSORS_VLLM_CONSTRAINTS=/workspace/safetensors-rig-source/constraints-vllm-torch280.txt
SAFETENSORS_UPGRADE_PIP=0
VLLM_PYTHON=/workspace/.venvs/safetensors-rig/bin/python
HF_HOME=/workspace/.hf
HF_HUB_CACHE=/workspace/.hf/hub
PYTHON_EXE=python3
